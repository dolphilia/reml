module Examples.Practical.CoreDiagnostics.AuditEnvelope

use Core.Diagnostics

fn record() {
  let envelope = Diagnostics.AuditEnvelope.from_parts(
    {
      "scenario.id": "CH3-DIAG-501",
      "effect.stage.required": "beta",
    },
    None,
    None,
    None,
  )
  Diagnostics.emit(envelope)
}

fn main() -> Str {
  record()
  "audit-envelope"
}
