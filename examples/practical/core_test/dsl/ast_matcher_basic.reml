module Examples.Practical.CoreTest.Dsl.AstMatcherBasic

use Core.Parse as Parse
use Core.Test.Dsl

type Expr =
  | Int(Int)
  | Add(Expr, Expr)

fn expr_parser() -> Parse.Parser<Expr> {
  Parse.fail("dsl-test-kit-pending")
}

fn main() -> Str {
  let outcome = test_parser(expr_parser()) {
    case "1 + 2" => Add(Int(1), Int(2))
    case "1 + 3" => Add(Int(1), ...)
  }
  match outcome with
    | Ok(_) -> "dsl:ok"
    | Err(_) -> "dsl:error"
}
