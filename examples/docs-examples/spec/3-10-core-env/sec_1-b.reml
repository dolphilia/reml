pub type EnvError = {
  kind: EnvErrorKind,
  message: Str,
  key: Option<Str>,
  context: Option<EnvContext>,
}

pub enum EnvErrorKind = NotFound | PermissionDenied | InvalidEncoding | UnsupportedPlatform | IoFailure

pub type EnvContext = {
  operation: Str,        // "get", "set", "remove"
  platform: PlatformInfo,
}
