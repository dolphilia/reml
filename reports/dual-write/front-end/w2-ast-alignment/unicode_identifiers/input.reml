# Unicode 識別子サンプル（SYNTAX-001 Step3）

# このファイルは Phase 2-5 で準備した検証用サンプルです。
# Phase 2-7 以降に Unicode 対応を有効化した際、lexer/parser テストで読み込む想定です。

module 国際化.識別子

let れむる = 42
let Καλημέρα = れむる + 1
let пользователь = Καλημέρα + れむる
let 데이터 = пользователь + 3
let café = 데이터 + 4

fn Δόκιμη(入力: i64) -> i64 {
  입력 + café
}
